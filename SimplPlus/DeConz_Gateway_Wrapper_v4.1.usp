/*
  DeConz_Gateway_Wrapper_v4.1.usp
  SIMPL+ Wrapper for DeConzWebSocketClient (SIMPL# class)

  v4.1 changes:
    - Added INTEGER_PARAMETER  Permanent_Resend_Seconds (default 30, range 1-3600)
    - Added DIGITAL_INPUT      Permanent_Resend_Enable  (global make-string-permanent)

  v4.0 changes:
    - Added INTEGER_PARAMETER  Alive_Timeout_Seconds  (default 15, range 5-3600)
    - Added INTEGER_PARAMETER  Use_TLS                (0 = WS, 1 = WSS)

  Programmer : martin@disnamic.com
*/

#SYMBOL_NAME "DeConz_Gateway v4.1"
#CATEGORY "46" "DeConZ_Zigbee"

#DEFAULT_VOLATILE
#ENABLE_STACK_CHECKING
#ENABLE_TRACE

#HELP_BEGIN
  DeConz Zigbee Gateway – SIMPL+ Wrapper  v4.1
  ---------------------------------------------
  Connects to a deCONZ gateway via WebSocket (RFC 6455, plain or TLS).
  All Zigbee device updates are routed internally via the static
  DeConzBroker to individual DeConz_Device modules – no signal wiring needed.

  INPUTS
    Enable_Websocket        Pulse → connect / reconnect
    Disable_Websocket       Pulse → disconnect cleanly
    Enable_Debug            High  → debug output on $DebugRX
    Permanent_Resend_Enable High  → global "make string permanent" for ALL
                            device modules (overrides their local enables);
                            Low  → each module's local enable applies

  OUTPUTS
    websocket_traffic_present   High while WS frames arrive;
                                drops Low after Alive_Timeout_Seconds of silence
    TCP_Status                  Raw SocketStatus value (0=no connect, 3=connected…)
    IP_To_Modules               Forwards IP to other modules if needed
    $DebugRX                    Debug text, max 250 chars per event

  PARAMETERS
    IP_Address              deCONZ hostname or IP
    API_Key                 Central deCONZ API key, distributed to all device
                            modules (device modules have no API key parameter)
    Port                    TCP port  (80 for WS, 443 for WSS)
    Alive_Timeout_Seconds   Seconds without traffic before websocket_traffic_present→0
                            Default 15, range 5-3600
    Use_TLS                 0 = plain WS (ws://)   1 = TLS/WSS (wss://)
    Permanent_Resend_Seconds  String re-assert interval in seconds for the
                            permanent-resend feature. Default 30, range 1-3600
#HELP_END

/*****
  Compiler Directives
*/
#USER_SIMPLSHARP_LIBRARY "DeConzZigbee"

/*
  I/O Declarations
*/
DIGITAL_INPUT  _SKIP_,_SKIP_,_SKIP_,_SKIP_,_SKIP_,_SKIP_,Enable_Websocket,Disable_Websocket,_SKIP_,Enable_Debug,_SKIP_,Permanent_Resend_Enable;

DIGITAL_OUTPUT _SKIP_,_SKIP_,_SKIP_,_SKIP_,_SKIP_,_SKIP_,websocket_traffic_present;
ANALOG_OUTPUT  TCP_Status;
STRING_OUTPUT  IP_To_Modules,_SKIP_,$DebugRX;

/*****
  Parameters
*/
INTEGER_PARAMETER Port, Alive_Timeout_Seconds, Use_TLS, Permanent_Resend_Seconds;
STRING_PARAMETER  IP_Address[64], API_Key[64];

#BEGIN_PARAMETER_PROPERTIES Port
  propValidUnits       = unitDecimal;
  propDefaultUnit      = unitDecimal;
  propDefaultValue     = 80d;
  propShortDescription = "WebSocket port  (80=WS  443=WSS)";
#END_PARAMETER_PROPERTIES

#BEGIN_PARAMETER_PROPERTIES IP_Address
  propValidUnits       = unitString;
  propDefaultValue     = "192.168.1.100";
  propShortDescription = "deCONZ Gateway IP or hostname";
#END_PARAMETER_PROPERTIES

#BEGIN_PARAMETER_PROPERTIES API_Key
  propValidUnits       = unitString;
  propDefaultValue     = "";
  propShortDescription = "Central deCONZ API key, distributed to all device modules";
#END_PARAMETER_PROPERTIES

#BEGIN_PARAMETER_PROPERTIES Alive_Timeout_Seconds
  propValidUnits       = unitDecimal;
  propDefaultUnit      = unitDecimal;
  propDefaultValue     = 15d;
  propShortDescription = "No-traffic timeout in seconds before traffic indicator drops (5-3600)";
#END_PARAMETER_PROPERTIES

#BEGIN_PARAMETER_PROPERTIES Use_TLS
  propValidUnits       = unitDecimal;
  propDefaultUnit      = unitDecimal;
  propDefaultValue     = 0d;
  propShortDescription = "0 = plain WS   1 = TLS/WSS";
#END_PARAMETER_PROPERTIES

#BEGIN_PARAMETER_PROPERTIES Permanent_Resend_Seconds
  propValidUnits       = unitDecimal;
  propDefaultUnit      = unitDecimal;
  propBounds           = 1d , 3600d ;
  propDefaultValue     = 30d;
  propShortDescription = "String re-assert interval in seconds (Make Permanent), default 30";
#END_PARAMETER_PROPERTIES

/*****
  SIMPL# Object
*/
DeConzWebSocketClient myGateway;

/*****
  Delegate Callbacks (SIMPL# → SIMPL+)
*/

CALLBACK FUNCTION OnConnectionStatus(INTEGER tcpStatus)
{
  TCP_Status = tcpStatus;
}

CALLBACK FUNCTION OnDebugOutput(STRING msg)
{
  $DebugRX = msg;
}

CALLBACK FUNCTION OnTrafficPresent(INTEGER active)
{
  IF (active)
    websocket_traffic_present = 1;
  ELSE
    websocket_traffic_present = 0;
}

/*****
  Input Handlers
*/
PUSH Enable_Websocket
{
  myGateway.SetDebug(Enable_Debug);
  myGateway.Connect();
}

PUSH Disable_Websocket
{
  myGateway.Disconnect();
}

CHANGE Enable_Debug
{
  myGateway.SetDebug(Enable_Debug);
}

CHANGE Permanent_Resend_Enable
{
  myGateway.SetPermanentResend(Permanent_Resend_Enable);
}

/*****
  Main
*/
Function Main()
{
  WaitForInitializationComplete();

  // Register delegates
  RegisterDelegate(myGateway, OnConnectionStatus, OnConnectionStatus);
  RegisterDelegate(myGateway, OnDebugOutput,      OnDebugOutput);
  RegisterDelegate(myGateway, OnTrafficPresent,   OnTrafficPresent);

  // Configure before Initialize
  myGateway.SetAliveTimeout(Alive_Timeout_Seconds);
  myGateway.SetTls(Use_TLS);
  myGateway.SetApiKey(API_Key);
  myGateway.SetPermanentResendInterval(Permanent_Resend_Seconds);
  myGateway.SetPermanentResend(Permanent_Resend_Enable);

  // Initialize
  myGateway.Initialize(IP_Address, Port);

  IP_To_Modules = IP_Address;
}
