[BEGIN]
  ObjTp=Hd
  Cmn1=||2DeConz Zigbee Gateway – SIMPL+ Wrapper  v4.1\\  ------------
  Cmn2=---------------------------------\\  Connects to a deCONZ gateway||1
  Cmn3=via WebSocket (RFC 6455, plain or TLS).\\  All Zigbee device updates||1
  Cmn4=are routed internally via the static\\  DeConzBroker to individual||1
  Cmn5=DeConz_Device modules – no signal wiring needed.\\\\  INPUTS\\
  Cmn6=||4Enable_Websocket        Pulse → connect / reconnect\\    Disable_Websocket||1
  Cmn7=||6Pulse → disconnect cleanly\\    Enable_Debug||<
  Cmn8=High  → debug output on $DebugRX\\    Permanent_Resend_Enable||1
  Cmn9=High  → global "make string permanent" for ALL\\||>
  Cmn10=||>device modules (overrides their local enables);\\||1
  Cmn11=||KLow  → each module's local enable applies\\
  Cmn12=\\  OUTPUTS\\    websocket_traffic_present   High while WS frames||1
  Cmn13=arrive;\\                                drops Low after Alive_Timeout_Seconds||1
  Cmn14=of silence\\    TCP_Status                  Raw SocketStatus value||1
  Cmn15=(0=no connect, 3=connected…)\\    IP_To_Modules||?
  Cmn16=Forwards IP to other modules if needed\\    $DebugRX||<
  Cmn17=||8Debug text, max 250 chars per event\\\\  PARAMETERS\\||3
  Cmn18=||1IP_Address              deCONZ hostname or IP\\    API_Key||5
  Cmn19=||<Central deCONZ API key, distributed to all device\\||1
  Cmn20=||Kmodules (device modules have no API key||1
  Cmn21=parameter)\\    Port                    TCP port  (80 for WS, 443||1
  Cmn22=for WSS)\\    Alive_Timeout_Seconds   Seconds without traffic before||1
  Cmn23=websocket_traffic_present→0\\                            Default||1
  Cmn24=15, range 5-3600\\    Use_TLS                 0 = plain WS (ws://)||1
  Cmn25=||21 = TLS/WSS (wss://)\\    Permanent_Resend_Seconds  String re-
  Cmn26=assert interval in seconds for the\\||L
  Cmn27=permanent-resend feature. Default 30, range 1-3600
[END]
