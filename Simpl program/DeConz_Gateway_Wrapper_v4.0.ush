[BEGIN]
  ObjTp=Hd
  Cmn1=||2DeConz Zigbee Gateway – SIMPL+ Wrapper  v4.0\\  ------------
  Cmn2=---------------------------------\\  Connects to a deCONZ gateway||1
  Cmn3=via WebSocket (RFC 6455, plain or TLS).\\  All Zigbee device updates||1
  Cmn4=are routed internally via the static\\  DeConzBroker to individual||1
  Cmn5=DeConz_Device modules – no signal wiring needed.\\\\  INPUTS\\
  Cmn6=||4Enable_Websocket        Pulse → connect / reconnect\\    Disable_Websocket||1
  Cmn7=||6Pulse → disconnect cleanly\\    Enable_Debug||<
  Cmn8=High  → debug output on $DebugRX\\\\  OUTPUTS\\    websocket_traffic_present||1
  Cmn9=||2High while WS frames arrive;\\||P
  Cmn10=drops Low after Alive_Timeout_Seconds of silence\\    TCP_Status||1
  Cmn11=||ARaw SocketStatus value (0=no connect, 3=connected…)\\
  Cmn12=||4IP_To_Modules               Forwards IP to other modules if||1
  Cmn13=needed\\    $DebugRX                    Debug text, max 250 chars||1
  Cmn14=per event\\\\  PARAMETERS\\    IP_Address              deCONZ hostname||1
  Cmn15=or IP\\    Port                    TCP port  (80 for WS, 443 for||1
  Cmn16=WSS)\\    Alive_Timeout_Seconds   Seconds without traffic before||1
  Cmn17=websocket_traffic_present→0\\                            Default||1
  Cmn18=15, range 5-3600\\    Use_TLS                 0 = plain WS (ws://)||1
  Cmn19=||21 = TLS/WSS (wss://)
[END]
